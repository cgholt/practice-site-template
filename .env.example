# ---------------------------------------------------------------------------
# Per-site configuration. Copy to `.env.local` and fill in for each client.
# Nothing here is committed — `.env*` is gitignored.
# ---------------------------------------------------------------------------

# Public base URL of the site. Used for metadata, SEO, sitemap.xml, robots.txt,
# and the JSON-LD business schema. No trailing slash.
SITE_URL=https://example.com

# --- Contact form (nodemailer -> ProtonMail SMTP by default) ---------------
# SMTP credentials for the mailbox that SENDS the notification email.
SMTP_USER=your-sending-address@example.com
SMTP_PASS=your-smtp-password
# Where contact-form submissions are delivered.
CONTACT_EMAIL=client-inbox@example.com

# --- Decap CMS GitHub OAuth (only needed for the hosted /admin editor) ------
# Create a GitHub OAuth app per client site. Callback URL:
#   https://<SITE_URL>/api/auth/callback
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# --- Analytics / ads (optional; leave blank to disable each) ----------------
# GA4 Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Ads tag, e.g. AW-000000000
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Google Ads conversion label (the part after the slash in the send_to value).
# Used to fire a conversion when the contact form is submitted.
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
